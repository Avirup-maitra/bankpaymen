<?php

namespace App\Console\Commands;

use App\Models\BankFile;
use Carbon\Carbon;
use Illuminate\Console\Command;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Schema;
use Illuminate\Support\Facades\Storage;
use Illuminate\Support\Str;
use Throwable;

class RebuildBankUploadsFromStorage extends Command
{
    protected $signature = 'bank:rebuild-uploads
        {--path=bank_uploads/2026/05 : Path relative to storage/app/private}
        {--bank=ALL : ALL, ICICI or SBI}
        {--created-by= : Existing user ID to assign as uploader}
        {--dry-run : Scan and report only}
        {--limit=0 : Maximum number of files to handle; 0 means all}
        {--chunk=500 : Number of records per database transaction}';

    protected $description =
        'Rebuild missing bank_files database records from files stored under storage/app/private';

    private int $scanned = 0;
    private int $eligible = 0;
    private int $created = 0;
    private int $existing = 0;
    private int $unsupported = 0;
    private int $failed = 0;

    public function handle(): int
    {
        $disk = Storage::disk('local');

        $requestedPath = trim((string) $this->option('path'), '/');
        $storagePath = $this->normalisePrivatePath($requestedPath);

        $bankFilter = strtoupper(trim((string) $this->option('bank')));

        if (!in_array($bankFilter, ['ALL', 'ICICI', 'SBI'], true)) {
            $this->error('--bank must be ALL, ICICI or SBI.');

            return self::FAILURE;
        }

        $dryRun = (bool) $this->option('dry-run');
        $limit = max(0, (int) $this->option('limit'));
        $chunkSize = max(1, (int) $this->option('chunk'));

        $createdBy = $this->resolveCreatedBy();

        if (!$disk->exists($storagePath)) {
            $this->error("Storage directory does not exist: {$storagePath}");
            $this->line(
                'Absolute expected location: ' .
                storage_path('app/' . $storagePath)
            );

            return self::FAILURE;
        }

        if (!Schema::hasTable('bank_files')) {
            $this->error('The bank_files table does not exist.');

            return self::FAILURE;
        }

        $this->newLine();
        $this->info('Bank upload recovery scan');
        $this->table(
            ['Setting', 'Value'],
            [
                ['Storage path', storage_path('app/' . $storagePath)],
                ['Bank filter', $bankFilter],
                ['Created by', $createdBy ?? 'NULL'],
                ['Dry run', $dryRun ? 'YES' : 'NO'],
                ['Limit', $limit === 0 ? 'No limit' : $limit],
                ['Chunk size', $chunkSize],
            ]
        );

        $files = $disk->allFiles($storagePath);

        if (empty($files)) {
            $this->warn('No files were found.');

            return self::SUCCESS;
        }

        sort($files);

        $buffer = [];

        foreach ($files as $relativePath) {
            $this->scanned++;

            if ($limit > 0 && $this->eligible >= $limit) {
                break;
            }

            $extension = strtolower(pathinfo($relativePath, PATHINFO_EXTENSION));

            if (!in_array($extension, ['xls', 'xlsx', 'csv', 'txt'], true)) {
                $this->unsupported++;
                continue;
            }

            $bankType = $this->detectBankType($relativePath);

            if ($bankType === null) {
                $this->unsupported++;
                continue;
            }

            if ($bankFilter !== 'ALL' && $bankType !== $bankFilter) {
                continue;
            }

            $this->eligible++;

            $metadata = $this->buildMetadata(
                $disk,
                $relativePath,
                $bankType,
                $createdBy
            );

            if ($this->recordAlreadyExists($metadata)) {
                $this->existing++;
                continue;
            }

            if ($dryRun) {
                if ($this->eligible <= 20) {
                    $this->line(
                        sprintf(
                            '[DRY RUN] %s | %s',
                            $bankType,
                            $relativePath
                        )
                    );
                }

                continue;
            }

            $buffer[] = $metadata;

            if (count($buffer) >= $chunkSize) {
                $this->insertChunk($buffer);
                $buffer = [];
            }
        }

        if (!$dryRun && !empty($buffer)) {
            $this->insertChunk($buffer);
        }

        $this->newLine();
        $this->table(
            ['Result', 'Count'],
            [
                ['Files scanned', $this->scanned],
                ['Eligible ICICI/SBI files', $this->eligible],
                ['Records created', $this->created],
                ['Existing records skipped', $this->existing],
                ['Unsupported/unidentified files', $this->unsupported],
                ['Failed records', $this->failed],
            ]
        );

        if ($dryRun) {
            $this->warn(
                'Dry run only. No database rows were created.'
            );
        } else {
            $this->info(
                'bank_files recovery completed. No transaction rows were deleted.'
            );
        }

        return $this->failed > 0
            ? self::FAILURE
            : self::SUCCESS;
    }

    private function normalisePrivatePath(string $path): string
    {
        if (Str::startsWith($path, 'private/')) {
            return $path;
        }

        return 'private/' . $path;
    }

