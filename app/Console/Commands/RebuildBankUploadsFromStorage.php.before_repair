private function resolveCreatedBy(): ?int
{
    $option = $this->option('created-by');

    if ($option !== null && $option !== '') {
        return (int) $option;
    }

    if (!Schema::hasTable('users')) {
        return null;
    }

    $superadmin = DB::table('users')
        ->whereRaw('UPPER(role) = ?', ['SUPERADMIN'])
        ->orderBy('id')
        ->value('id');

    if ($superadmin !== null) {
        return (int) $superadmin;
    }

    $firstUser = DB::table('users')
        ->orderBy('id')
        ->value('id');

    return $firstUser !== null ? (int) $firstUser : null;
}

    private function detectBankType(string $relativePath): ?string
    {
        $searchText = strtoupper(
            str_replace(['-', '_', '.'], ' ', $relativePath)
        );

        if (
            Str::contains($searchText, 'ICICI') ||
            Str::contains($searchText, 'ICIC')
        ) {
            return 'ICICI';
        }

        if (
            Str::contains($searchText, 'SBI') ||
            Str::contains($searchText, 'STATE BANK')
        ) {
            return 'SBI';
        }

        /*
         * Optional fallback based on folder names.
         */
        $segments = array_map(
            static fn (string $segment): string => strtoupper($segment),
            explode('/', $relativePath)
        );

        if (in_array('ICICI', $segments, true)) {
            return 'ICICI';
        }

        if (in_array('SBI', $segments, true)) {
            return 'SBI';
        }

        return null;
    }

    private function buildMetadata(
        $disk,
        string $relativePath,
        string $bankType,
        ?int $createdBy
    ): array {
        $filename = basename($relativePath);
        $size = null;
        $modifiedTimestamp = null;

        try {
            $size = $disk->size($relativePath);
        } catch (Throwable) {
            // Keep size as null.
        }

        try {
            $modifiedTimestamp = $disk->lastModified($relativePath);
        } catch (Throwable) {
            // Keep timestamp as null.
        }

        $fileDate = $modifiedTimestamp
            ? Carbon::createFromTimestamp($modifiedTimestamp)
            : now();

        $values = [];

        $this->setIfColumnExists(
            $values,
            'original_filename',
            $filename
        );

        $this->setIfColumnExists(
            $values,
            'filename',
            $filename
        );

        $this->setIfColumnExists(
            $values,
            'stored_filename',
            $filename
        );

        $this->setIfColumnExists(
            $values,
            'file_path',
            $relativePath
        );

        $this->setIfColumnExists(
            $values,
            'stored_path',
            $relativePath
        );

        $this->setIfColumnExists(
            $values,
            'path',
            $relativePath
        );

        $this->setIfColumnExists(
            $values,
            'disk',
            'local'
        );

        $this->setIfColumnExists(
            $values,
            'mime_type',
            $this->guessMimeType($filename)
        );

        $this->setIfColumnExists(
            $values,
            'file_size',
            $size
        );

        $this->setIfColumnExists(
            $values,
            'size',
            $size
        );

        $this->setIfColumnExists(
            $values,
            'bank_type',
            $bankType
        );

        $this->setIfColumnExists(
            $values,
            'bank',
            $bankType
        );

        $this->setIfColumnExists(
            $values,
            'status',
            'RECEIVED'
        );

        $this->setIfColumnExists(
            $values,
            'processing_status',
            'RECEIVED'
        );

        $this->setIfColumnExists(
            $values,
            'received_at',
            $fileDate
        );

        $this->setIfColumnExists(
            $values,
            'uploaded_at',
            $fileDate
        );

        $this->setIfColumnExists(
            $values,
            'created_by',
            $createdBy
        );

        $this->setIfColumnExists(
            $values,
            'created_at',
            now()
        );

        $this->setIfColumnExists(
            $values,
            'updated_at',
            now()
        );

        return $values;
    }private function detectBankType(string $relativePath): ?string
{
    $filename = strtoupper(basename($relativePath));

    /*
     * SBI files seen in the existing storage:
     * rev_SBI_21928.txt
     * SBI_....csv
     */
    if (
        Str::contains($filename, 'SBI') ||
        Str::startsWith($filename, 'REV_SBI_')
    ) {
        return 'SBI';
    }

    /*
     * ICICI H2H files seen in the existing storage:
     * BRCILCHN_HLCDN_100426_479460136.xls
     * BRCILRAJ_HLCDN_100426_479455079.xls
     */
    if (
        Str::contains($filename, 'ICICI') ||
        (
            Str::startsWith($filename, 'BRCIL') &&
            Str::contains($filename, 'HLCDN')
        )
    ) {
        return 'ICICI';
    }

    return null;
}
    private function setIfColumnExists(
        array &$values,
        string $column,
        mixed $value
    ): void {
        if (!Schema::hasColumn('bank_files', $column)) {
            return;
        }

        $values[$column] = $value;
    }

    private function recordAlreadyExists(array $metadata): bool
    {
        $pathColumn = $this->firstExistingColumn([
            'file_path',
            'stored_path',
            'path',
        ]);

        if ($pathColumn !== null && isset($metadata[$pathColumn])) {
            if (
                DB::table('bank_files')
                    ->where($pathColumn, $metadata[$pathColumn])
                    ->exists()
            ) {
                return true;
            }
        }

        $nameColumn = $this->firstExistingColumn([
            'original_filename',
            'filename',
            'stored_filename',
        ]);

        if ($nameColumn !== null && isset($metadata[$nameColumn])) {
            $query = DB::table('bank_files')
                ->where($nameColumn, $metadata[$nameColumn]);

            if (
                Schema::hasColumn('bank_files', 'file_size') &&
                isset($metadata['file_size'])
            ) {
                $query->where('file_size', $metadata['file_size']);
            }

            if ($query->exists()) {
                return true;
            }
        }

        return false;
    }

    private function firstExistingColumn(array $columns): ?string
    {
        foreach ($columns as $column) {
            if (Schema::hasColumn('bank_files', $column)) {
                return $column;
            }
        }

        return null;
    }

    private function insertChunk(array $records): void
    {
        DB::beginTransaction();

        try {
            foreach ($records as $record) {
                try {
                    BankFile::query()->create($record);
                    $this->created++;
                } catch (Throwable $exception) {
                    $this->failed++;

                    $this->error(
                        'Failed: ' .
                        ($record['original_filename']
                            ?? $record['filename']
                            ?? $record['file_path']
                            ?? 'unknown file') .
                        ' | ' .
                        $exception->getMessage()
                    );
                }
            }

            DB::commit();
        } catch (Throwable $exception) {
            DB::rollBack();

            $this->failed += count($records);

            $this->error(
                'Chunk failed: ' . $exception->getMessage()
            );
        }
    }

    private function guessMimeType(string $filename): string
    {
        return match (strtolower(pathinfo($filename, PATHINFO_EXTENSION))) {
            'xls' => 'application/vnd.ms-excel',
            'xlsx' => 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
            'csv' => 'text/csv',
            'txt' => 'text/plain',
            default => 'application/octet-stream',
        };
    }
